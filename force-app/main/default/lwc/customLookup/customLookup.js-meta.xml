<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <target>lightning__HomePage</target>
    </targets>

    <targetConfigs>
        <targetConfig targets="lightning__HomePage">
            <property name="apiName" type="String" required="true" default="Account" label="Enter Object API Name"/>
            <property name="objectLabel" type="String" required="true" default="Account" label="Enter Object Label" />
            <property name="iconName" type="String" required="true" default="standard:account" label="Enter Icon for Object" description="check SLDS for info on icons"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>